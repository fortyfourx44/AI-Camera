# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude vision-capable model (Sonnet recommended)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Where chunks/screenshots/db live (relative to project root)
DATA_DIR=./data
RECORDINGS_DIR=./recordings
SCREENSHOTS_DIR=./screenshots

# Recording chunk length in seconds (smaller = faster feedback, larger = fewer LLM calls)
CHUNK_SECONDS=60

# Number of frames to extract per chunk for the LLM
FRAMES_PER_CHUNK=8

# Path to ffmpeg binary (default: looks in PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
